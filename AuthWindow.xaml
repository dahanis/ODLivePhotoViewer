<Window x:Class="OneDriveLivePhotoViewer.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="Sign in to OneDrive Photos"
        Width="1040" Height="780"
        MinWidth="860" MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBg}">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="OneDrive sign-in" FontSize="24" FontWeight="SemiBold" Foreground="#111827" />
                <TextBlock Text="Sign in normally. The app only captures the OneDrive Photos authorization header in memory." Foreground="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <Button x:Name="CloseButton" Content="Close" DockPanel.Dock="Right" MinWidth="90" Click="CloseButton_Click" />
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12" Margin="0,0,0,12">
            <DockPanel>
                <Ellipse x:Name="StatusDot" Width="10" Height="10" Fill="#F59E0B" Margin="0,0,10,0" DockPanel.Dock="Left" />
                <TextBlock x:Name="StatusText" Text="Loading secure sign-in..." VerticalAlignment="Center" Foreground="#111827" />
            </DockPanel>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
            <wv2:WebView2 x:Name="Browser" />
        </Border>

        <DockPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock Text="Tip: wait until the status says the token was captured, then close this window." Foreground="{StaticResource MutedText}" VerticalAlignment="Center" />
            <Button x:Name="UseTokenButton" DockPanel.Dock="Right" Content="Use captured sign-in" Style="{StaticResource PrimaryButton}" MinWidth="170" IsEnabled="False" Click="UseTokenButton_Click" />
        </DockPanel>
    </Grid>
</Window>
