<Window x:Class="OneDriveLivePhotoViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="OneDrive Live Photo Viewer"
        Width="1420" Height="900"
        MinWidth="1120" MinHeight="740"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource WindowBg}">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="OneDrive Live Photo Viewer" FontSize="28" FontWeight="SemiBold" Foreground="#111827" />
                <TextBlock Text="Recover, select, export, and play iPhone Live Photos backed up by OneDrive." Foreground="{StaticResource MutedText}" Margin="0,4,0,0" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="OpenLogButton" Content="Open log" Click="OpenLogButton_Click" />
                <Button x:Name="SignOutButton" Content="Sign out" MinWidth="100" IsEnabled="False" Click="SignOutButton_Click" />
                <Button x:Name="SignInButton" Content="Sign in" Style="{StaticResource PrimaryButton}" MinWidth="110" Click="SignInButton_Click" />
            </StackPanel>
        </DockPanel>

        <Border Grid.Row="1" Style="{StaticResource Card}" Margin="0,0,0,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,16,8">
                    <TextBlock Text="Local OneDrive photo folder or file" FontWeight="SemiBold" Foreground="#111827" />
                    <TextBox x:Name="LocalPathBox" IsReadOnly="True" Margin="0,6,0,0" Text="Choose a OneDrive folder, or choose one specific .HEIC/.JPG file" />
                </StackPanel>

                <Button Grid.Column="1" Grid.Row="0" Content="Choose folder" MinWidth="124" VerticalAlignment="Bottom" Click="ChooseFolderButton_Click" />
                <Button Grid.Column="2" Grid.Row="0" Content="Choose file" MinWidth="112" VerticalAlignment="Bottom" Click="ChooseFileButton_Click" />
                <Button x:Name="ScanButton" Grid.Column="3" Grid.Row="0" Content="Scan" MinWidth="86" VerticalAlignment="Bottom" IsEnabled="False" Click="ScanButton_Click" />
                <Button x:Name="DownloadSelectedButton" Grid.Column="4" Grid.Row="0" Content="Download selected" MinWidth="142" VerticalAlignment="Bottom" IsEnabled="False" Click="DownloadSelectedButton_Click" />
                <Button x:Name="DownloadAllButton" Grid.Column="5" Grid.Row="0" Content="Download all" MinWidth="112" VerticalAlignment="Bottom" IsEnabled="False" Click="DownloadAllButton_Click" />
                <Button x:Name="ExportSelectedButton" Grid.Column="6" Grid.Row="0" Content="Export selected copy" MinWidth="154" VerticalAlignment="Bottom" IsEnabled="False" Click="ExportSelectedButton_Click" />

                <StackPanel Grid.Column="0" Grid.Row="1" Grid.ColumnSpan="7" Orientation="Horizontal" Margin="0,6,0,0">
                    <Border CornerRadius="8" Background="#EEF2FF" Padding="10,6" Margin="0,0,8,0">
                        <TextBlock x:Name="CloudPathText" Text="Cloud path: not selected" Foreground="#3730A3" />
                    </Border>
                    <Border CornerRadius="8" Background="#ECFDF5" Padding="10,6" Margin="0,0,8,0">
                        <TextBlock x:Name="AuthStatusText" Text="Not signed in" Foreground="#166534" />
                    </Border>
                    <Border CornerRadius="8" Background="#FFF7ED" Padding="10,6" Margin="0,0,8,0">
                        <TextBlock x:Name="CountText" Text="0 Live Photos" Foreground="#9A3412" />
                    </Border>
                    <Button x:Name="ExportAllButton" Content="Export all copies" MinWidth="100" IsEnabled="False" Click="ExportAllButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="500" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource Card}" Padding="0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="16,14,16,8">
                        <TextBlock Text="Library" FontSize="18" FontWeight="SemiBold" DockPanel.Dock="Left" />
                        <TextBlock x:Name="SelectionText" Text="No selected items" Foreground="{StaticResource MutedText}" DockPanel.Dock="Right" />
                    </DockPanel>
                    <WrapPanel Grid.Row="1" Margin="12,0,12,8">
                        <Button x:Name="SelectAllButton" Content="Select all" MinWidth="86" IsEnabled="False" Click="SelectAllButton_Click" />
                        <Button x:Name="ClearSelectionButton" Content="Clear" MinWidth="70" IsEnabled="False" Click="ClearSelectionButton_Click" />
                        <Button x:Name="InvertSelectionButton" Content="Invert" MinWidth="76" IsEnabled="False" Click="InvertSelectionButton_Click" />
                    </WrapPanel>
                    <ListView x:Name="LivePhotoList" Grid.Row="2" BorderThickness="0" ItemsSource="{Binding Items}" SelectionChanged="LivePhotoList_SelectionChanged" MouseDoubleClick="LivePhotoList_MouseDoubleClick">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="" Width="44">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Photo" Width="160" DisplayMemberBinding="{Binding Name}" />
                                <GridViewColumn Header="Date" Width="118" DisplayMemberBinding="{Binding DisplayDate}" />
                                <GridViewColumn Header="MOV" Width="78" DisplayMemberBinding="{Binding ExpectedVideoSizeText}" />
                                <GridViewColumn Header="Status" Width="100" DisplayMemberBinding="{Binding Status}" />
                            </GridView>
                        </ListView.View>
                    </ListView>
                </Grid>
            </Border>

            <Border Grid.Column="2" Style="{StaticResource Card}" Padding="0" ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <DockPanel Margin="16,14,16,10">
                        <StackPanel DockPanel.Dock="Left">
                            <TextBlock x:Name="ViewerTitle" Text="Viewer" FontSize="18" FontWeight="SemiBold" />
                            <TextBlock x:Name="ViewerSubtitle" Text="Select a photo. HEIC stills are converted to a temporary JPEG preview; click or hover to play the Live Photo." Foreground="{StaticResource MutedText}" Margin="0,3,0,0" />
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                            <Button x:Name="PlayButton" Content="Download / Make live" MinWidth="155" IsEnabled="False" Click="PlayButton_Click" />
                            <Button x:Name="OpenFolderButton" Content="Open folder" MinWidth="110" IsEnabled="False" Click="OpenFolderButton_Click" />
                        </StackPanel>
                    </DockPanel>
                    <Border Grid.Row="1" Background="#111827" CornerRadius="0,0,18,18" ClipToBounds="True">
                        <wv2:WebView2 x:Name="Viewer" />
                    </Border>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3" Style="{StaticResource Card}" Margin="0,16,0,0" Padding="14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ProgressBar x:Name="Progress" Width="220" Height="8" Minimum="0" Maximum="100" Value="0" VerticalAlignment="Center" />
                <TextBlock x:Name="StatusBarText" Grid.Column="1" Text="Ready." Foreground="{StaticResource MutedText}" Margin="12,0,0,0" VerticalAlignment="Center" />
                <Button x:Name="CancelButton" Grid.Column="2" Content="Cancel" IsEnabled="False" MinWidth="90" Click="CancelButton_Click" />
            </Grid>
        </Border>
    </Grid>
</Window>
